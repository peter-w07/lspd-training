# Cloudflare Pages headers config
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Long-cache static assets (immutable until file content changes)
/styles.css
  Cache-Control: public, max-age=3600

/app.js
  Cache-Control: public, max-age=3600

# Data file — short cache so edits propagate quickly
/data.json
  Cache-Control: public, max-age=300
  Content-Type: application/json; charset=utf-8

# HTML — no long cache so updates push immediately
/
  Cache-Control: public, max-age=60
/index.html
  Cache-Control: public, max-age=60
